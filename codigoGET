from http.server import HTTPServer, BaseHTTPRequestHandler

class Servidor(BaseHTTPRequestHandler):

    def do_GET(self):
        self.send_response(200)
        self.end_headers()
        self.wfile.write(b"Servidor funcionando")

HTTPServer(("10.87.38.14", 8000), Servidor).serve_forever()

# O código cria um servidor HTTP local que responde "Servidor funcionando" para requisições GET.
